# ============================================================================
# DATABASE (Supabase)
# ============================================================================
# Get from Supabase → Settings → Database → Connection string
#
# DATABASE_URL: Use the "Session pooling" connection (port 6543) for runtime queries
# This provides better performance and connection pooling for serverless environments
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# DIRECT_URL: Use the "Direct connection" (port 5432) for migrations
# Required for running database migrations locally
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Generate with: openssl rand -base64 32
# Use different secrets for development and production!
JWT_SECRET="your_secret_here"
AUTH_SECRET="your_secret_here"

# AUTH_URL: Your app URL (http://localhost:3000 for dev, https://your-domain.com for production)
AUTH_URL="http://localhost:3000"

# ============================================================================
# EMAIL (Resend)
# ============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"

# ============================================================================
# FILE STORAGE (Supabase)
# ============================================================================
# Get from Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# ============================================================================
# CRON JOBS
# ============================================================================
# Generate with: openssl rand -base64 32
# Used to authenticate cron job requests
CRON_SECRET="your_cron_secret_here"

# ============================================================================
# ERROR TRACKING (Sentry) - OPTIONAL
# ============================================================================
# Get from: https://sentry.io/settings/projects/
# Leave empty to disable Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ============================================================================
# APP CONFIGURATION
# ============================================================================
# NEXT_PUBLIC_APP_URL: Your app URL (used in emails and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NODE_ENV: Environment mode
NODE_ENV="development"

# ============================================================================
# RATE LIMITING (Upstash Redis) - OPTIONAL
# ============================================================================
# Provision via Vercel Marketplace → "Upstash For Redis". Env vars are injected
# automatically on Vercel under the UP_KV_* prefix — the rate limiter checks all
# three naming conventions below in order, so no manual aliasing is needed:
#   1. UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN  (manual / canonical)
#   2. KV_REST_API_URL / KV_REST_API_TOKEN                (legacy Vercel KV)
#   3. UP_KV_REST_API_URL / UP_KV_REST_API_TOKEN          (current Marketplace)
#
# For local dev, leave empty — rate limiting falls back to an in-process Map
# (resets on hot-reload, fine for development). To test against real Redis
# locally, run `npx vercel env pull .env.development.local`.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================================================
# CAL.COM v2 API (reschedule / cancel in-app)
# ============================================================================
# Create at https://app.cal.com/settings/developer/api-keys (account-level, not OAuth)
CAL_COM_API_KEY=
# Defaults to https://api.cal.com/v2 when unset. Override for staging.
CAL_COM_API_BASE=https://api.cal.com/v2

# ============================================================================
# POSTHOG PRODUCT ANALYTICS — EU Cloud project token (NEXT_PUBLIC_*, safe to expose)
# ============================================================================
# Get from: https://eu.posthog.com/settings/project (EU Cloud, not US)
NEXT_PUBLIC_POSTHOG_KEY=phc_replace_me
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
